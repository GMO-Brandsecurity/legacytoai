# ==================================================
# 発注AI (HacchuAI) 環境変数設定
# このファイルを .env.local にコピーして値を設定
# ==================================================

# --- Supabase ---
# https://supabase.com でプロジェクト作成後、
# Project Settings > API からコピー
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- OAuth プロバイダー (Supabase Auth で設定) ---
# Google: https://console.cloud.google.com で OAuth 2.0 クライアント作成
# → Supabase Dashboard > Auth > Providers > Google に設定
#
# LINE: https://developers.line.biz で LINE Login チャネル作成
# → Supabase Dashboard > Auth > Providers > LINE に設定
#
# Supabase側の Callback URL: https://your-project.supabase.co/auth/v1/callback

# --- デプロイ先 URL ---
# Vercel等にデプロイ後、Supabase Auth > URL Configuration に設定
# Site URL: https://your-domain.com
# Redirect URLs: https://your-domain.com/auth/callback
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- ステージング環境保護 ---
# Vercel Preview デプロイ時にBasic認証をかけるパスワード
# Vercelダッシュボードの Environment Variables で STAGING_PASSWORD を設定
# （Preview環境のみに適用されるよう設定してください）
STAGING_PASSWORD=

# --- 管理者設定 ---
# 管理者画面にアクセスできるメールアドレス（カンマ区切りで複数指定可）
ADMIN_EMAILS=your-admin@example.com
NEXT_PUBLIC_ADMIN_EMAILS=your-admin@example.com
